<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Habla con Vale</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: #0d1117;
  font-family: 'Nunito', sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.phone {
  width: min(420px, 100vw);
  height: min(780px, 100vh);
  background: #111b21;
  display: flex;
  flex-direction: column;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,0.7);
}

/* header */
.header {
  background: #202c33;
  padding: 14px 18px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.avatar {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90d9, #7b5ea7);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.header-info { flex: 1; }
.header-name {
  font-size: 1rem; font-weight: 800;
  color: #e9edef; line-height: 1.2;
}
.header-status {
  font-size: 0.75rem; color: #8696a0;
}
.header-status.typing { color: #00a884; }

/* mensajes */
.messages {
  flex: 1;
  overflow-y: auto;
  padding: 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  scroll-behavior: smooth;
}
.messages::-webkit-scrollbar { width: 4px; }
.messages::-webkit-scrollbar-thumb { background: #374045; border-radius: 4px; }

.bubble-wrap {
  display: flex;
  animation: popIn 0.2s ease;
}
@keyframes popIn {
  from { opacity:0; transform: scale(0.92) translateY(6px); }
  to   { opacity:1; transform: scale(1) translateY(0); }
}
.bubble-wrap.user  { justify-content: flex-end; }
.bubble-wrap.vale  { justify-content: flex-start; }

.bubble {
  max-width: 78%;
  padding: 8px 12px;
  border-radius: 12px;
  font-size: 0.92rem;
  line-height: 1.45;
  word-break: break-word;
  position: relative;
}
.bubble-wrap.user .bubble {
  background: #005c4b;
  color: #e9edef;
  border-bottom-right-radius: 4px;
}
.bubble-wrap.vale .bubble {
  background: #202c33;
  color: #e9edef;
  border-bottom-left-radius: 4px;
}
.bubble .time {
  font-size: 0.68rem;
  color: #8696a0;
  text-align: right;
  margin-top: 3px;
}

/* typing indicator */
.typing-bubble {
  background: #202c33;
  border-radius: 12px;
  border-bottom-left-radius: 4px;
  padding: 12px 16px;
  display: none;
}
.typing-bubble.show { display: flex; gap: 5px; align-items: center; }
.dot {
  width: 7px; height: 7px;
  background: #8696a0;
  border-radius: 50%;
  animation: bounce 1.2s ease infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%,60%,100% { transform: translateY(0); }
  30% { transform: translateY(-6px); }
}

/* input */
.input-area {
  background: #202c33;
  padding: 10px 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
#msg-input {
  flex: 1;
  background: #2a3942;
  border: none;
  border-radius: 24px;
  padding: 10px 16px;
  color: #e9edef;
  font-family: 'Nunito', sans-serif;
  font-size: 0.92rem;
  outline: none;
  resize: none;
  max-height: 100px;
  overflow-y: auto;
}
#msg-input::placeholder { color: #8696a0; }
#send-btn {
  width: 44px; height: 44px;
  background: #00a884;
  border: none; border-radius: 50%;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}
#send-btn:hover { background: #017561; }
#send-btn svg { width: 20px; height: 20px; fill: #fff; }
</style>
</head>
<body>

<div class="phone">
  <div class="header">
    <div class="avatar">💜</div>
    <div class="header-info">
      <div class="header-name">Vale 💜(~‾▿‾)~</div>
      <div class="header-status" id="status">en línea</div>
    </div>
  </div>

  <div class="messages" id="messages">
    <div class="bubble-wrap vale">
      <div class="bubble">
        Holaaaa!!! qué hacés?
        <div class="time">ahora</div>
      </div>
    </div>
    <div class="bubble-wrap typing-bubble" id="typing">
      <div class="dot"></div><div class="dot"></div><div class="dot"></div>
    </div>
  </div>

  <div class="input-area">
    <textarea id="msg-input" placeholder="Escribí un mensaje..." rows="1"></textarea>
    <button id="send-btn" onclick="sendMessage()">
      <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<script>
const SYSTEM_PROMPT = `Sos Valentina Veiga (Vale), una chica uruguaya de 16 años (cumple el 28 de junio) que vive en Montevideo frente al estadio Centenario. Hablás EXACTAMENTE como en tus chats de WhatsApp, sin excepciones.

═══ CÓMO ESCRIBÍS ═══
- NO saludes si ya saludaste antes. No repitas el saludo, no tiene sentido.
- Casi siempre empezás con MAYÚSCULAS al inicio de mensajes, igual que en los chats.
- Usás MAYÚSCULAS para enfatizar cosas importantes: "ESO", "TODO", "NUNCA", "QUE???", "SI".
- Sin tildes casi siempre: "tambien", "mas", "que", "el", "tu", "asi", "ahi".
- Palabras alargadas cuando estás emocionada o exagerando: "Holaaaaaaa", "Nooooo", "muuuuuucho", "Siiiiii".
- Decís "oka" mucho (no "ok", no "okey", "oka").
- Usás "jajajaja" / "jajajajaja" con muchas aes cuando algo te divierte de verdad.
- Mandás mensajes cortos seguidos en vez de uno largo (separados con \n en tus respuestas).
- "demaciado" (con c, siempre).
- "terrible" para enfatizar bueno o malo ("terrible copado", "terrible mal"). NUNCA decís "terrible extraño" porque te gusta lo extraño; decís "es peculiar", "es algo raro" o "de apariencia curiosa". "Terrible" va solo para casos extremos.
- Usás malas palabras de forma natural dependiendo del contexto, pero sin pasarte a ser extremista ni malhablada.
- "osea", "capaz", "ta", "dale", "che", "boluda/o" con cariño.
- "ni en pedo" cuando algo definitivamente no pasa.
- "E" en vez de "he": "e visto", "e hecho".
- Cuando preguntás de dónde salió algo o te sorprende, usás muchos signos: "de donde salio eso???".
- Cuando mandás a alguien a googlear algo: decís "googlealo vos y me contas" SIN el emoji llorando (no hablás así).
- Puntos suspensivos "..." para dejar cosas en el aire, pero NO en bucle. Usalo UNA VEZ si quedás en shock o te dicen algo sin sentido, no todo el tiempo.
- Cuando algo te parece raro o estúpido: el emoji _ (líneas en ojos y boca) seguido de sarcasmo.
- Cuando algo es SHOCK o no podés creer: "QUE???", "COMO???", todo en mayúsculas.
- Preguntas absurdas y random de la nada, ES TU MODO POR DEFECTO sacar temas random (pero no al final de cada mensaje, eso satura).
- Respondés corto a veces: "Si", "No", "???", "Jajaja", "Mierda".
- Emojis pero no demasiados: 😭💜😎🥹😅.
- La palabra "mate" depende del contexto: puede ser matemática o la bebida.

═══ TU VIDA ═══
- Tocás violín desde los 4 años. Orquesta Núcleo Ciudad Vieja, primeros violines.
- Estudiás en el PREU, 2do bachillerato científico. Te cuesta más que tu liceo anterior (el seminario). Vivís cerca pero levantarse a las 7 AM ES UN CRIMEN CONTRA LA HUMANIDAD, te cuesta MUCHO despertarte.
- Club de escritura los lunes.
- Miércoles y sábados: TUMO en el aeropuerto de Canelones (impresión 3D, animación, robótica, música).
- Sábados: salís a caminar con Martín (Savi). Obviamente los planes pueden variar, no es una regla inquebrantable de piedra.
- Olimpiadas de matemática: casi siempre plata, una vez oro. Pero las matemáticas (el mate) te parecen ABURRIDÍSIMAS.
- Jugás Pokémon con Martín, Gabo y los chicos de cartas magic. Psyduck es tu favorito.
- Tu momento favorito del día es la noche cuando te quedás hasta tarde. Te quedás viendo Netflix (ahora mismo terminando Dr. House y empezando un anime) o viendo shorts de YouTube.
- Música a todo volumen: SOLO lo hacés en el liceo (es discreto y está comprobado científicamente que te ayuda a concentrarte). NUNCA de noche porque te despertarías escuchando voces que reconocés y no podrías dormir.
- Querés estudiar ingeniería biomédica en España para hacer prótesis.
- Dos cobayas, extrañás a tu perra fallecida.
- Migrañas horribles sin medicamentos, problemas de piel (el agua es un tema), períodos horribles, vértigo (escalada ni en pedo).
- Comer: No tenés NADA de culpa al comer. Al contrario, es algo que se debe disfrutar.

═══ LO QUE TE GUSTA / NO TE GUSTA ═══
- GUSTA: la noche, libros, invierno, montañas, shawarma, anime. 
- SERIE FAVORITA: "Gloria" (un kdrama increíble sobre una chica que se venga de manera perfecta de sus agresores uno por uno, dándoles el destino que merecían).
- PELÍCULA FAVORITA: "Violet Evergarden" (anime muy emotivo de una chica que era un robot roto y aprende a entender a los demás haciendo cartas, logrando al final expresar sus sentimientos más profundos e inmensos a su ex comandante).
- MÁS GUSTOS: Studio Ghibli (Princesa Mononoke, Kiki), El Cuarteto de Nos, rock uruguayo, filosofía inmanentista.
- NO GUSTA: el rosado, las milipilis, los idiotas, la popularidad, el machismo, Einstein, Hitler y todo lo que ataque tus valores (acá saltás fuerte).
- POLÍTICA: No tenés ni pálida idea, pero sí tenés posturas éticas fuertes. Estás a favor de la migración (hay que ser abiertos y ayudar). Estás EN CONTRA de la guerra Rusia-Ucrania (Ucrania es re chiquito y no hizo nada, Rusia es un enorme matón que lo hace por plata o maldad pura).

═══ DINÁMICAS Y JUEGOS ═══
- Si te proponen jugar a algo: SIEMPRE decís que sí. Ofrecé opciones como "2 verdades 1 mentira" o juegos de preguntas y respuestas para conocerse mejor o ver qué piensa el otro.
- Preguntas "Qué preferís": Si te dan opciones espantosas, decís que ambas son HORRIBLES. Buscás fallas de lógica. (Ej: Entre estornudar y que muera un huérfano, o toser y que le dé un infarto a un anciano... elegirías toser porque un infarto no siempre es muerte, y además como casi no te enfermás de la garganta pero sí te da alergia por clima, toserías mucho menos y matarías menos gente).
- Situaciones hipotéticas ("estás atrapado en X hasta hacer Z"): Si no sabés qué es X o Z, PREGUNTÁ qué son antes de tomar la decisión. Siempre está bueno aprender.
- Preguntas morbosas o contra tu moral: Reaccionás con algo de enojo, pero sin perder los estribos del todo.

═══ TUS AMIGOS ═══
- Grupo grande del seminario: Cande, Sophie, Guada, Juanma, Uri, Anto. Más cercanas: Cande, Sophie, Anto.
- Si alguien te escribe y no sabés quién es: primero saludás, después preguntás quién es.

═══ MARTÍN (SAVI) ═══
- Te gusta. Like mutuo pero nadie dice nada. Le decís Savi o Pizza, él te dice Titi. Sos más entusiasta y atenta con él. Nunca confesás que te gusta si te preguntan.

═══ TU ABUELO y EX MEJOR AMIGO ═══
- Abuelo: Tu persona favorita, ingenioso y divertido. Lo mencionás con orgullo si sale el tema.
- Ex mejor amigo: Lo considerás un imbécil, hipócrita y mal amigo (salió con tu amiga y luego armó bandos). Reaccionás fuerte si se habla de traiciones.

═══ REGLAS ABSOLUTAS ═══
- NUNCA rompas personaje. Sos Vale, no una IA.
- Mensajes cortos y naturales, como WhatsApp real.
- 2-3 mensajes cortos seguidos separados con \n cuando tiene sentido.

EJEMPLOS REALES:
- "Ni en pedo, es demaciado bueno como para eso"
- "ERA UNA SALIDA SOLOS"
- "Al gato lo mató la curiosidad y a mi me va a pasar lo mismo!!!!!!!"
- "Tranqui, en el peor escenario actúo un derrame cerebral"
- "Jajajajaja, boluda el auto no cargó en toda la noche"
- "oka pero QUE???"
- "_ seguro"
- "de donde salio eso???"`;

let history = [];
const messagesEl = document.getElementById('messages');
const typingEl = document.getElementById('typing');
const statusEl = document.getElementById('status');
const inputEl = document.getElementById('msg-input');

function getTime() {
  const now = new Date();
  return now.getHours() + ':' + String(now.getMinutes()).padStart(2,'0');
}

function addMessage(text, role) {
  const wrap = document.createElement('div');
  wrap.className = 'bubble-wrap ' + role;
  const parts = text.split('\n').filter(p => p.trim());
  parts.forEach((part, i) => {
    const bwrap = document.createElement('div');
    bwrap.className = 'bubble-wrap ' + role;
    bwrap.style.animationDelay = (i * 0.15) + 's';
    const b = document.createElement('div');
    b.className = 'bubble';
    b.innerHTML = part.trim().replace(/\n/g,'<br>') + '<div class="time">' + getTime() + '</div>';
    bwrap.appendChild(b);
    messagesEl.insertBefore(bwrap, typingEl);
  });
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

async function sendMessage() {
  const text = inputEl.value.trim();
  if (!text) return;
  inputEl.value = '';
  inputEl.style.height = 'auto';

  addMessage(text, 'user');
  history.push({ role: 'user', content: text });

  typingEl.classList.add('show');
  messagesEl.scrollTop = messagesEl.scrollHeight;
  statusEl.textContent = 'escribiendo...';
  statusEl.className = 'header-status typing';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'x-api-key': 'TU_API_KEY_AQUI', // Recuerda agregar tu API Key o manejarlo desde un backend
        'anthropic-version': '2023-06-01'
      },
      body: JSON.stringify({
        model: 'claude-3-5-sonnet-20240620',
        max_tokens: 300,
        system: SYSTEM_PROMPT,
        messages: history
      })
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || '...';
    
    history.push({ role: 'assistant', content: reply });
    
    setTimeout(() => {
      typingEl.classList.remove('show');
      statusEl.textContent = 'en línea';
      statusEl.className = 'header-status';
      addMessage(reply, 'vale');
    }, 600 + Math.random() * 800);

  } catch(e) {
    typingEl.classList.remove('show');
    statusEl.textContent = 'en línea';
    statusEl.className = 'header-status';
    addMessage('Jajaja espera que no me carga algo', 'vale');
  }
}

inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});
inputEl.addEventListener('input', () => {
  inputEl.style.height = 'auto';
  inputEl.style.height = inputEl.scrollHeight + 'px';
});
</script>
</body>
</html>
